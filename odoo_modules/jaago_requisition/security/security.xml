<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_requisition" model="ir.module.category">
        <field name="name">Requisition</field>
        <field name="description">Helps you manage requisition approvals.</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_requisition_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_requisition"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_requisition_approver" model="res.groups">
        <field name="name">Approver</field>
        <field name="category_id" ref="module_category_requisition"/>
        <field name="implied_ids" eval="[(4, ref('group_requisition_user'))]"/>
    </record>

    <record id="group_requisition_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="module_category_requisition"/>
        <field name="implied_ids" eval="[(4, ref('group_requisition_approver'))]"/>
    </record>

    <!-- Record Rules -->
    <record id="requisition_rule_user" model="ir.rule">
        <field name="name">Personal Requisitions</field>
        <field name="model_id" ref="model_approval_request"/>
        <field name="domain_force">[('request_owner_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_requisition_user'))]"/>
    </record>

    <record id="requisition_rule_approver" model="ir.rule">
        <field name="name">Approver Requisitions</field>
        <field name="model_id" ref="model_approval_request"/>
        <field name="domain_force">['|', ('request_owner_id.user_id', '=', user.id), ('approval_history_ids.approver_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_requisition_approver'))]"/>
    </record>

    <record id="requisition_rule_admin" model="ir.rule">
        <field name="name">Administrator Requisitions</field>
        <field name="model_id" ref="model_approval_request"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_requisition_admin'))]"/>
    </record>
</odoo>
